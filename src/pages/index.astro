---
import { Image } from "astro:assets"

import Base from "~/components/base.astro"
import Link from "~/components/link.astro"

import localImage from "~/assets/avatar.png"
import localAi from "~/assets/notbyai-en.svg"

import { externalLinks } from "~/utils"

function calculateBirthday() {
  var ageDifMs = Date.now() - new Date(2001, 9, 24).getTime()
  var ageDate = new Date(ageDifMs)
  return Math.abs(ageDate.getUTCFullYear() - 1970)
}
---

<Base>
  <header class="mx-auto flex min-h-svh w-full max-w-6xl flex-col justify-center gap-6 p-6">
    <section class="flex flex-col items-center justify-center gap-8 lg:flex-row">
      <div class="flex flex-col lg:flex-1">
        <h1 class="pb-1 text-3xl font-black sm:text-4xl">Hiya, I'm Sora!</h1>
        <p class="pb-6 text-xs italic sm:text-sm">previously known as Sxnic [saw-nik]</p>

        <div class="flex flex-col text-sm sm:text-base">
          <p class="py-2">
            I'm a {calculateBirthday()} year old furry programmer and railway enthusiast from The Netherlands.
          </p>
          <p class="pb-2">
            I have a passion for technology, language learning, cooking and almost anything railway
            related.
          </p>
          <p>I like running and self hosting my own websites and services.</p>
          <p class="text-xs italic sm:text-sm">Because big tech stinks</p>

          <p class="pt-2">I am simplistic by design, and that's okay.</p>
          <p class="text-xs italic sm:text-sm">
            Because who needs all the bells and whistles to be able to live a normal life?
          </p>
        </div>

        <!-- links mobile -->
        <section class="flex flex-row items-center justify-start gap-4 pt-4 lg:hidden">
          {externalLinks.map((l) => <Link url={l.url} icon={l.icon} tooltip={l.name} />)}
        </section>
      </div>
      <div class="relative order-first shrink-0 lg:order-last">
        <Image
          class="pointer-events-none text-transparent"
          src={localImage}
          alt="avatar"
          format="avif"
          width={400}
        />
      </div>
    </section>
    <!-- links desktop -->
    <section class="flex flex-row items-center justify-end gap-4 max-lg:hidden">
      {externalLinks.map((l) => <Link url={l.url} icon={l.icon} tooltip={l.name} />)}
    </section>
    <!-- footer -->
    <section class="flex flex-col items-start justify-between gap-y-4 sm:flex-row sm:items-start">
      <div class="flex flex-row gap-2">
        <a class="font-bold hover:underline hover:opacity-75" href="blog">Blog</a>
      </div>
      <a href="https://notbyai.fyi" target="_blank">
        <Image src={localAi} alt="notbyai" />
      </a>
    </section>
  </header>
</Base>
